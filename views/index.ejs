<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Attendance Runs</title>
    <link rel="stylesheet" href="/assets/styles.css" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Discord Attendance Tracker</p>
            <h1>Runs overview with exports and deep analytics.</h1>
            <p class="intro">
              Keep the main dashboard clean, then open each webinar to inspect voice engagement,
              candidate behavior, channel performance, and attendance trends in detail.
            </p>
            <div class="hero-actions">
              <a href="/" class="button-link <%= currentPage === "runs" ? "is-active" : "secondary-link" %>">Runs</a>
              <a href="/users" class="button-link <%= currentPage === "users" ? "is-active" : "secondary-link" %>">Users DB</a>
            </div>
          </div>

          <aside class="hero-side">
            <div class="mini-card">
              <strong><%= runs.length %></strong>
              <span>Total webinars</span>
            </div>
            <div class="mini-card">
              <strong><%= runs.filter((run) => run.is_active).length %></strong>
              <span>Currently live</span>
            </div>
            <div class="mini-card">
              <strong><%= runs.reduce((sum, run) => sum + run.total_participants, 0) %></strong>
              <span>Total tracked attendees</span>
            </div>
          </aside>
        </div>
      </section>

      <section class="grid-layout">
        <div class="stack">
          <section class="card">
            <div class="page-title-row">
              <div>
                <p class="eyebrow">Overview</p>
                <h2>Webinar runs</h2>
              </div>
              <span class="muted-chip">Compact view with drill-down pages</span>
            </div>

            <% if (runs.length === 0) { %>
              <div class="empty-state">
                <h2>No tracking runs yet</h2>
                <p>Use <strong>/tracking start</strong> or <strong>/tracking schedule</strong> in Discord to create one.</p>
              </div>
            <% } else { %>
              <section class="run-grid">
                <% runs.forEach((run) => { %>
                  <article class="run-card">
                    <div class="card-header">
                      <div>
                        <p class="eyebrow">Run #<%= run.id %></p>
                        <h3><%= run.title %></h3>
                      </div>
                      <span class="status <%= run.is_active ? "live" : "idle" %>"><%= run.status %></span>
                    </div>

                    <div class="stats-grid compact-stats">
                      <div class="stat-box">
                        <div class="stat-label">Participants</div>
                        <div class="stat-value"><%= run.total_participants %></div>
                      </div>
                      <div class="stat-box">
                        <div class="stat-label">Channels</div>
                        <div class="stat-value"><%= run.total_channels %></div>
                      </div>
                      <div class="stat-box">
                        <div class="stat-label">Duration</div>
                        <div class="stat-value"><%= run.total_run_duration %></div>
                      </div>
                      <div class="stat-box">
                        <div class="stat-label">Started</div>
                        <div class="stat-value small-stat"><%= run.started_display %></div>
                      </div>
                    </div>

                    <div class="actions">
                      <a href="/runs/<%= run.id %>/export.xlsx" class="button-link">Download Excel</a>
                      <a href="/runs/<%= run.id %>" class="button-link secondary-link">Show More</a>
                    </div>
                  </article>
                <% }) %>
              </section>
            <% } %>
          </section>
        </div>

        <aside class="stack">
          <section class="card">
            <p class="eyebrow">Insight Panels</p>
            <h2>What the detail page shows</h2>
            <div class="stats-grid">
              <div class="stat-box">
                <div class="stat-label">Top Attendees</div>
                <div class="stat-value">Time Ranked</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Most Rejoined</div>
                <div class="stat-value">Session Count</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Earliest Arrivals</div>
                <div class="stat-value">Arrival Order</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Busiest Channels</div>
                <div class="stat-value">Duration Mix</div>
              </div>
            </div>
          </section>

          <section class="card">
            <p class="eyebrow">Note</p>
            <h2>Candidate insight scope</h2>
            <p class="intro">
              The current analytics page is based on voice attendance only. It highlights consistent
              listeners, rejoin behavior, presence length, and cross-channel activity to help identify interested candidates.
            </p>
          </section>
        </aside>
      </section>
    </main>
  </body>
</html>

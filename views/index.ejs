<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Attendance Runs</title>
    <link rel="stylesheet" href="/assets/styles.css" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <div>
          <p class="eyebrow">Discord Attendance Tracker</p>
          <h1>Whole-server tracking runs with per-channel Excel sheets.</h1>
          <p class="intro">
            Start tracking from Discord, let the bot capture attendance across every voice channel,
            and use this dashboard to download one Excel workbook where each VC becomes its own sheet.
          </p>
          <div class="actions">
            <a href="/" class="button-link">Runs</a>
            <a href="/users" class="button-link secondary-link">Users DB</a>
          </div>
        </div>
      </section>

      <section class="list">
        <% if (runs.length === 0) { %>
          <div class="empty-state">
            <h2>No tracking runs yet</h2>
            <p>Use <strong>/tracking start</strong> or <strong>/tracking schedule</strong> in Discord to create one.</p>
          </div>
        <% } %>

        <% runs.forEach((run) => { %>
          <article class="card">
            <div class="card-header">
              <div>
                <p class="eyebrow">Run #<%= run.id %></p>
                <h2><%= run.title %></h2>
              </div>
              <span class="status <%= run.is_active ? "live" : "idle" %>"><%= run.status %></span>
            </div>

            <dl class="meta">
              <div>
                <dt>Guild ID</dt>
                <dd><%= run.guild_id %></dd>
              </div>
              <div>
                <dt>Created</dt>
                <dd><%= run.created_display %></dd>
              </div>
              <div>
                <dt>Scheduled</dt>
                <dd><%= run.scheduled_start_display %> -> <%= run.scheduled_end_display %></dd>
              </div>
              <div>
                <dt>Actual Window</dt>
                <dd><%= run.started_display %> -> <%= run.ended_display %></dd>
              </div>
            </dl>

            <div class="actions">
              <a href="/runs/<%= run.id %>/export.xlsx" class="button-link">Download Excel</a>
            </div>

            <div class="report">
              <h3>Tracked channels</h3>
              <% if (run.channels.length === 0) { %>
                <p class="empty-inline">No voice activity captured for this run.</p>
              <% } else { %>
                <% run.channels.forEach((channel) => { %>
                  <section class="subcard">
                    <div class="card-header">
                      <div>
                        <h3><%= channel.channel_name %></h3>
                        <p class="notes"><%= channel.rows.length %> participant(s)</p>
                      </div>
                    </div>

                    <table>
                      <thead>
                        <tr>
                          <th>User</th>
                          <th>Total duration</th>
                          <th>Percentage</th>
                          <th>Sessions</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% channel.rows.forEach((entry) => { %>
                          <tr>
                            <td><strong><%= entry.username %></strong><br /><small><%= entry.userId %></small></td>
                            <td><%= entry.totalDuration %></td>
                            <td><%= entry.percentage %></td>
                            <td><%= entry.totalSessions %></td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </section>
                <% }) %>
              <% } %>
            </div>
          </article>
        <% }) %>
      </section>
    </main>
  </body>
</html>

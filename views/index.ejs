<!-- Easter egg: MUPC layouts carry a quiet Oneway signature for anyone reading source at midnight. -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= guildName %> Runs</title>
    <%- include("partials/theme-init") %>
    <link rel="stylesheet" href="/assets/styles.css" />
  </head>
  <body
    data-live-page="<%= livePage %>"
    data-live-guild-id="<%= guildId %>"
    data-live-snapshot="<%= liveSnapshot %>"
  >
    <%- include("partials/utility-menu") %>
    <main class="page">
      <section class="hero">
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="eyebrow"><%= guildName %></p>
            <h1>Workshop attendance, framed for quick review.</h1>
            <p class="intro">
              Review runs, exports, and engagement analytics for this server only, then open each
              session for deeper attendance detail.
            </p>
            <div class="hero-actions">
              <a href="<%= serverBasePath %>" class="button-link <%= currentPage === "runs" ? "is-active" : "secondary-link" %>">Runs</a>
              <a href="<%= serverBasePath %>/users" class="button-link <%= currentPage === "users" ? "is-active" : "secondary-link" %>">Users DB</a>
            </div>
          </div>

          <aside class="hero-side">
            <div class="mini-card">
              <strong><%= runs.length %></strong>
              <span>Total workshops in this server</span>
            </div>
            <div class="mini-card">
              <strong><%= runs.filter((run) => run.is_active).length %></strong>
              <span>Currently live</span>
            </div>
            <div class="mini-card">
              <strong><%= runs.reduce((sum, run) => sum + run.total_participants, 0) %></strong>
              <span>Total tracked attendees</span>
            </div>
          </aside>
        </div>
      </section>

      <section class="grid-layout">
        <div class="stack">
          <section class="card">
            <div class="page-title-row">
              <div>
                <p class="eyebrow">Overview</p>
                <h2>Workshop archive</h2>
              </div>
              <span class="muted-chip"><%= guildName %></span>
            </div>

            <% if (runs.length === 0) { %>
              <div class="empty-state">
                <h2>No workshops tracked yet for this server</h2>
                <p>Use <strong>/tracking start</strong> or <strong>/tracking schedule</strong> in Discord when the next session begins.</p>
              </div>
            <% } else { %>
              <section class="run-grid">
                <% runs.forEach((run) => { %>
                  <article class="run-card">
                    <div class="run-shell run-shell-header">
                      <div class="card-header">
                        <div>
                          <p class="eyebrow">Run #<%= run.id %></p>
                          <h3><%= run.title %></h3>
                        </div>
                        <span
                          class="status <%= run.is_active ? "live" : run.status === "scheduled" ? "scheduled" : "idle" %>"
                        ><%= run.status %></span>
                      </div>
                    </div>

                    <div class="run-shell run-shell-metrics">
                      <div class="stats-grid compact-stats">
                        <div class="stat-box">
                          <div class="stat-label">Participants</div>
                          <div class="stat-value"><%= run.total_participants %></div>
                        </div>
                        <div class="stat-box">
                          <div class="stat-label">Channels</div>
                          <div class="stat-value"><%= run.total_channels %></div>
                        </div>
                        <div class="stat-box">
                          <div class="stat-label">Duration</div>
                          <div
                            class="stat-value"
                            data-duration-clock
                            data-started-at="<%= run.started_at ?? "" %>"
                            data-ended-at="<%= run.ended_at ?? "" %>"
                            data-status="<%= run.status %>"
                          ><%= run.total_run_duration %></div>
                        </div>
                        <div class="stat-box">
                          <div class="stat-label"><%= run.status === "scheduled" ? "Scheduled" : "Started" %></div>
                          <div class="stat-value small-stat"><%= run.status === "scheduled" ? run.scheduled_start_display : run.started_display %></div>
                        </div>
                      </div>
                    </div>

                    <div class="run-shell run-shell-actions">
                      <div class="actions">
                        <a href="<%= serverBasePath %>/runs/<%= run.id %>/export.xlsx" class="button-link">Download Excel</a>
                        <a href="<%= serverBasePath %>/runs/<%= run.id %>" class="button-link secondary-link">Show More</a>
                      </div>
                    </div>
                  </article>
                <% }) %>
              </section>
            <% } %>
          </section>
        </div>

        <aside class="stack">
          <section class="card">
            <p class="eyebrow">Insight Panels</p>
            <h2>What the workshop page shows</h2>
            <div class="stats-grid">
              <div class="stat-box">
                <div class="stat-label">Top Attendees</div>
                <div class="stat-value">Time Ranked</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Most Rejoined</div>
                <div class="stat-value">Session Count</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Earliest Arrivals</div>
                <div class="stat-value">Arrival Order</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Busiest Channels</div>
                <div class="stat-value">Duration Mix</div>
              </div>
            </div>
          </section>

          <section class="card">
            <p class="eyebrow">Scope</p>
            <h2>Server-only analytics</h2>
            <p class="intro">
              This view is scoped to <strong><%= guildName %></strong> only. Runs, people, exports,
              and live updates here no longer mix data from any other server.
            </p>
          </section>
        </aside>
      </section>
    </main>
    <script src="/assets/dashboard-live.js"></script>
  </body>
</html>

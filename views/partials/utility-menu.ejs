<div class="floating-utility" data-utility-menu>
  <button type="button" class="floating-utility-toggle" aria-label="Open dashboard utilities" aria-expanded="false" data-utility-toggle>H</button>
  <div class="floating-utility-panel" aria-label="Dashboard utilities">
    <a href="/" class="utility-action">Home</a>
    <div class="theme-tool" aria-label="Theme customizer">
      <p class="theme-tool-title">Theme</p>
      <div class="theme-swatches" data-theme-swatches>
        <button type="button" class="theme-swatch is-blue" data-theme-preset="blue" aria-label="Use blue theme"></button>
        <button type="button" class="theme-swatch is-ember" data-theme-preset="ember" aria-label="Use ember theme"></button>
        <button type="button" class="theme-swatch is-mint" data-theme-preset="mint" aria-label="Use mint theme"></button>
        <button type="button" class="theme-swatch is-rose" data-theme-preset="rose" aria-label="Use rose theme"></button>
      </div>
      <label class="theme-color-field">
        Primary
        <input type="color" value="#62e6ff" data-theme-primary />
      </label>
      <label class="theme-color-field">
        Glow
        <input type="color" value="#7c5cff" data-theme-secondary />
      </label>
    </div>
  </div>
</div>

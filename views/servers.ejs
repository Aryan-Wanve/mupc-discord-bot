<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Choose A Server</title>
    <%- include("partials/theme-init") %>
    <link rel="stylesheet" href="/assets/styles.css" />
  </head>
  <body class="servers-page" data-live-page="<%= livePage %>" data-live-snapshot="<%= liveSnapshot %>">
    <%- include("partials/utility-menu") %>
    <main class="page">
      <section class="hero">
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Attendance Dashboard</p>
            <h1>Choose the server you want to review.</h1>
            <p class="intro">
              The dashboard is now organized per server. Pick a Discord server below to open its runs,
              users, exports, and live attendance analytics.
            </p>
          </div>

          <aside class="hero-side" data-live-region="servers-summary">
            <div class="mini-card">
              <strong><%= servers.length %></strong>
              <span>Servers with attendance data</span>
            </div>
            <div class="mini-card">
              <strong><%= servers.reduce((sum, server) => sum + server.runCount, 0) %></strong>
              <span>Total tracked runs</span>
            </div>
            <div class="mini-card">
              <strong><%= servers.reduce((sum, server) => sum + server.activeCount, 0) %></strong>
              <span>Runs live right now</span>
            </div>
          </aside>
        </div>
      </section>

      <section class="card server-browser" data-live-region="server-browser">
        <div class="page-title-row">
          <div>
            <p class="eyebrow">Servers</p>
            <h2>Server selector</h2>
          </div>
          <span class="muted-chip">Open one dashboard at a time</span>
        </div>

        <% if (servers.length === 0) { %>
          <div class="empty-state">
            <h2>No server data yet</h2>
            <p>Once the bot tracks attendance in a server, it will appear here.</p>
          </div>
        <% } else { %>
          <section class="server-grid server-grid-compact">
            <% servers.forEach((server) => { %>
              <article class="server-card">
                <div class="server-card-top">
                  <div class="card-header">
                    <div class="server-card-heading">
                      <% if (server.guildIconUrl) { %>
                        <img
                          src="<%= server.guildIconUrl %>"
                          alt="<%= server.guildName %> icon"
                          class="server-avatar"
                        />
                      <% } else { %>
                        <div class="server-avatar server-avatar-fallback">
                          <%= server.guildName.trim().slice(0, 2).toUpperCase() %>
                        </div>
                      <% } %>
                      <div class="server-title-block">
                        <h3><%= server.guildName %></h3>
                        <p class="server-id-line">Guild ID: <span><%= server.guildId %></span></p>
                      </div>
                    </div>
                    <span class="status <%= server.activeCount > 0 ? "live" : "idle" %>">
                      <%= server.activeCount > 0 ? `${server.activeCount} live` : "idle" %>
                    </span>
                  </div>
                </div>

                <div class="server-bento">
                  <div class="server-tile server-tile-number">
                    <div class="stat-label">Runs</div>
                    <div class="stat-value"><%= server.runCount %></div>
                  </div>
                  <div class="server-tile server-tile-number">
                    <div class="stat-label">Participants</div>
                    <div class="stat-value"><%= server.trackedParticipants %></div>
                  </div>
                  <div class="server-tile server-tile-wide">
                    <div class="stat-label">Latest Activity</div>
                    <div class="server-meta-value"><%= server.latestActivityDisplay %></div>
                  </div>
                  <div class="server-tile server-tile-action">
                    <a href="/servers/<%= server.guildId %>" class="button-link">Open Server</a>
                  </div>
                </div>
              </article>
            <% }) %>
          </section>
        <% } %>
      </section>
    </main>
    <script src="/assets/dashboard-live.js"></script>
  </body>
</html>

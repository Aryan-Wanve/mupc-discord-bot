<!-- Easter egg: the registry keeps a soft Oneway watermark for anyone spelunking the template tree. -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Users Database</title>
    <link rel="stylesheet" href="/assets/styles.css" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">MUPC Member Registry</p>
            <h1>Workshop attendance history for every club member.</h1>
            <p class="intro">
              Inspect MUPC registration data, workshop participation history, average attendance depth,
              and the raw voice records that power the export sheets.
            </p>
            <div class="hero-actions">
              <a href="/" class="button-link <%= currentPage === "runs" ? "is-active" : "secondary-link" %>">Runs</a>
              <a href="/users" class="button-link <%= currentPage === "users" ? "is-active" : "secondary-link" %>">Users DB</a>
              <a href="/users/export.csv" class="button-link">Download Users CSV</a>
            </div>
          </div>

          <aside class="hero-side">
            <div class="mini-card">
              <strong><%= registrations.length %></strong>
              <span>Registered users</span>
            </div>
            <div class="mini-card">
              <strong><%= users.length %></strong>
              <span>Tracked profiles</span>
            </div>
            <div class="mini-card">
              <strong><%= sessions.length %></strong>
              <span>Raw session rows</span>
            </div>
          </aside>
        </div>
      </section>

      <section class="grid-layout">
        <div class="stack">
          <section class="card">
            <div class="page-title-row">
              <div>
                <p class="eyebrow">Registry</p>
                <h2>Registered users</h2>
              </div>
              <span class="muted-chip">Enrollment-linked identities</span>
            </div>

            <% if (registrations.length === 0) { %>
              <p class="empty-inline">No users have registered an enrollment number yet.</p>
            <% } else { %>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>User</th>
                      <th>Enrollment No</th>
                      <th>Registered</th>
                      <th>Last updated</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% registrations.forEach((user) => { %>
                      <tr>
                        <td><strong><%= user.username %></strong><br /><small><%= user.user_id %></small></td>
                        <td><%= user.enrollment_no %></td>
                        <td><%= user.registered_display %></td>
                        <td><%= user.updated_display %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </section>

          <section class="card">
            <div class="page-title-row">
              <div>
                <p class="eyebrow">History</p>
                <h2>Raw session rows</h2>
              </div>
              <span class="muted-chip">Low-level attendance data</span>
            </div>

            <% if (sessions.length === 0) { %>
              <p class="empty-inline">No raw session data yet.</p>
            <% } else { %>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Run</th>
                      <th>Channel</th>
                      <th>User</th>
                      <th>Enrollment No</th>
                      <th>Joined</th>
                      <th>Left</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% sessions.forEach((session) => { %>
                      <tr>
                        <td>#<%= session.tracking_run_id %></td>
                        <td><%= session.channel_name %><br /><small><%= session.channel_id %></small></td>
                        <td><strong><%= session.username %></strong><br /><small><%= session.user_id %></small></td>
                        <td><%= session.enrollment_no %></td>
                        <td><%= session.joined_display %></td>
                        <td><%= session.left_display %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </section>
        </div>

        <aside class="stack">
          <section class="card">
            <div class="page-title-row">
              <div>
                <p class="eyebrow">Totals</p>
                <h2>User attendance summary</h2>
              </div>
              <span class="muted-chip">Cross-webinar candidate summary</span>
            </div>
            <% if (users.length === 0) { %>
              <p class="empty-inline">No tracked users yet.</p>
            <% } else { %>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>User</th>
                      <th>Enrollment No</th>
                      <th>Workshops Joined</th>
                      <th>Avg % Attended</th>
                      <th>Total tracked time</th>
                      <th>Session count</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% users.forEach((user) => { %>
                      <tr>
                        <td><strong><%= user.username %></strong><br /><small><%= user.userId %></small></td>
                        <td><%= user.enrollmentNo %></td>
                        <td><%= user.totalRunsJoined %></td>
                        <td><%= user.averagePercentage %></td>
                        <td><%= user.totalDuration %></td>
                        <td><%= user.totalSessions %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </section>

          <section class="card">
            <p class="eyebrow">Identity Flow</p>
            <h2>Registration rule</h2>
            <p class="intro">
              Each Discord user can register exactly one enrollment number using <strong>/register</strong>.
              If they try again later, the bot tells them they are already registered.
            </p>
            <div class="stats-grid">
              <div class="stat-box">
                <div class="stat-label">Command</div>
                <div class="stat-value">/register</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Duplicate Handling</div>
                <div class="stat-value">Blocked</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">User Export</div>
                <div class="stat-value">CSV Ready</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Analytics</div>
                <div class="stat-value">Cross-run</div>
              </div>
            </div>
          </section>
        </aside>
      </section>
    </main>
  </body>
</html>

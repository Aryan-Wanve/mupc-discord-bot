<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Users Database</title>
    <link rel="stylesheet" href="/assets/styles.css" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <div>
          <p class="eyebrow">Attendance Database</p>
          <h1>Raw user records and session history.</h1>
          <p class="intro">
            This page shows the raw stored attendance data so you can inspect who was tracked,
            how many sessions they have, and the underlying join and leave rows in the database.
          </p>
          <div class="actions">
            <a href="/" class="button-link">Runs</a>
            <a href="/users" class="button-link secondary-link">Users DB</a>
          </div>
        </div>
      </section>

      <section class="card">
        <h2>Registered users</h2>
        <% if (registrations.length === 0) { %>
          <p class="empty-inline">No users have registered an enrollment number yet.</p>
        <% } else { %>
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Enrollment No</th>
                <th>Registered</th>
                <th>Last updated</th>
              </tr>
            </thead>
            <tbody>
              <% registrations.forEach((user) => { %>
                <tr>
                  <td><strong><%= user.username %></strong><br /><small><%= user.user_id %></small></td>
                  <td><%= user.enrollment_no %></td>
                  <td><%= user.registered_display %></td>
                  <td><%= user.updated_display %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </section>

      <section class="card">
        <h2>User totals</h2>
        <% if (users.length === 0) { %>
          <p class="empty-inline">No tracked users yet.</p>
        <% } else { %>
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Enrollment No</th>
                <th>Total tracked time</th>
                <th>Session count</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach((user) => { %>
                <tr>
                  <td><strong><%= user.username %></strong><br /><small><%= user.user_id %></small></td>
                  <td><%= user.enrollment_no || "Not registered" %></td>
                  <td><%= user.total_display %></td>
                  <td><%= user.session_count %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </section>

      <section class="card">
        <h2>Raw session rows</h2>
        <% if (sessions.length === 0) { %>
          <p class="empty-inline">No raw session data yet.</p>
        <% } else { %>
          <table>
            <thead>
              <tr>
                <th>Run</th>
                <th>Channel</th>
                <th>User</th>
                <th>Enrollment No</th>
                <th>Joined</th>
                <th>Left</th>
              </tr>
            </thead>
            <tbody>
              <% sessions.forEach((session) => { %>
                <tr>
                  <td>#<%= session.tracking_run_id %></td>
                  <td><%= session.channel_name %><br /><small><%= session.channel_id %></small></td>
                  <td><strong><%= session.username %></strong><br /><small><%= session.user_id %></small></td>
                  <td><%= session.enrollment_no %></td>
                  <td><%= session.joined_display %></td>
                  <td><%= session.left_display %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </section>
    </main>
  </body>
</html>
